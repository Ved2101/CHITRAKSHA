# Groq API Key (Obtain from https://console.groq.com)
# Required for actual Llama 3.1 8B chat functionality. If left empty,
# the server will automatically run using its empathetic mock therapist responses.
GROQ_API_KEY=gsk_your_key_here

# Gemini API Key (Obtain from Google AI Studio)
# If provided, Chitraksha will prioritize using Gemini (gemini-1.5-flash) for replies.
GEMINI_API_KEY=your_gemini_key_here

# Secret key for JWT auth token signing. Keep this secure in production.
JWT_SECRET_KEY=chitraksha-secret-key-change-this-in-prod

# SQLite database file path (stored locally in backend directory)
DATABASE_PATH=chitraksha.db

# Flask API Port
PORT=5000
DEBUG=True
